{
  "name": "@chronicstone/typed-xlsx-docs",
  "private": true,
  "scripts": {
    "dev": "nuxt prepare && nuxt dev",
    "build": "nuxt prepare && nuxt build && node scripts/postbuild-static.mjs",
    "generate": "nuxt prepare && nuxt generate && node scripts/postbuild-static.mjs",
    "preview": "nuxt preview",
    "typecheck": "nuxt prepare",
    "twoslash:verify": "nuxt prepare && nuxt-content-twoslash verify",
    "check": "bun run build && bun run twoslash:verify"
  },
  "dependencies": {
    "@chronicstone/typed-xlsx": "workspace:*",
    "@shikijs/vitepress-twoslash": "^4.0.2",
    "better-sqlite3": "^12.5.0",
    "docus": "latest",
    "nuxt": "^4.2.2",
    "nuxt-content-twoslash": "^0.4.0",
    "shiki": "^4.0.2",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.24.6"
  },
  "packageManager": "bun@1.3.6"
}
