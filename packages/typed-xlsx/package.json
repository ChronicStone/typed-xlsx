{
  "name": "@chronicstone/typed-xlsx",
  "version": "0.2.17",
  "description": "High-quality type-safe Excel reporting.",
  "keywords": [
    "excel",
    "reporting",
    "typescript",
    "xlsx"
  ],
  "homepage": "https://typed-xlsx.vercel.app/",
  "bugs": "https://github.com/ChronicStone/typed-xlsx/issues",
  "license": "MIT",
  "author": "ChronicStone <cthao.pro@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChronicStone/typed-xlsx",
    "directory": "packages/typed-xlsx"
  },
  "files": [
    "build",
    "README.md"
  ],
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "default": "./build/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:reports": "mkdir -p .reports/vitest && vitest run --reporter=default --reporter=json --reporter=junit --outputFile.json=.reports/vitest/results.json --outputFile.junit=.reports/vitest/results.junit.xml && node ./scripts/generate-test-report.mjs",
    "examples": "bun run ./scripts/generate-examples.ts",
    "examples:financial-report:50k": "bun run ./scripts/generate-financial-report-50k.ts",
    "benchmark:stream": "bun run ./scripts/benchmark-stream.ts",
    "build": "vp pack",
    "prepack": "vp pack",
    "pack:check": "npm pack --dry-run",
    "check": "tsc --noEmit && vitest run && vp pack && npm pack --dry-run"
  },
  "dependencies": {
    "deepmerge-ts": "^5.1.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.3.1",
    "@types/node": "^20.12.7",
    "vitest": "^3.2.4"
  }
}
