{
  "name": "xlsmith-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace root for xlsmith package and documentation",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "pack:check": "turbo run pack:check",
    "check": "turbo run check",
    "examples:build": "turbo run build --filter=xlsmith-examples",
    "benchmark:build": "turbo run build --filter=xlsmith-benchmark",
    "docs:dev": "turbo run dev --filter=xlsmith-docs",
    "docs:build": "turbo run build --filter=xlsmith-docs",
    "docs:generate": "turbo run generate --filter=xlsmith-docs",
    "docs:twoslash": "turbo run twoslash:verify --filter=xlsmith-docs",
    "docs:check": "turbo run check --filter=xlsmith-docs && turbo run twoslash:verify --filter=xlsmith-docs",
    "ci": "turbo run check --filter=!xlsmith-benchmark && turbo run twoslash:verify --filter=xlsmith-docs",
    "prepare": "vp config",
    "changeset": "changeset",
    "release:status": "changeset status --verbose",
    "release:version": "changeset version && bun install",
    "release:publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "turbo": "2.5.8",
    "typescript": "6.0.2",
    "vite-plus": "0.1.15"
  },
  "packageManager": "bun@1.3.6"
}
