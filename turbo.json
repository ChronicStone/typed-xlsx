{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "build/**",
        "generated/**",
        "artifacts/**",
        "showcase/**/artifact/**",
        ".output/**"
      ]
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": [".output/**"]
    },
    "twoslash:verify": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "pack:check": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "check": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
